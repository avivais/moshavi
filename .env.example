# Copy to `.env` in the repo root and fill in values. Do not commit `.env`.
# Server (EC2) `.env` should have at least: ADMIN_PASSWORD, NODE_ENV=production, PORT=3000
# Optional on server: NEXT_PUBLIC_GA_ID, YOUTUBE_CHANNEL_PLAYLISTS_URL

# =============================================================================
# Local machine — scripts/publish-set.sh (encode set + rsync + register via API)
# =============================================================================
# You almost always only need this one line: the same secret string as `ADMIN_PASSWORD`
# on the production server (Bearer token for /api/admin). Get it from the server’s
# `/var/www/moshavi/.env` if you don’t have it saved locally.
ADMIN_PASSWORD=

# Optional overrides (defaults match scripts/deploy.sh — same EC2 host, user ubuntu,
# app /var/www/moshavi, key ~/.ssh/VaisenKey.pem). Uncomment only if your setup differs.
# MOSHAVI_ADMIN_TOKEN=
# MOSHAVI_BASE_URL=https://moshavi.com
# MOSHAVI_SSH_HOST=ec2-98-84-90-118.compute-1.amazonaws.com
# MOSHAVI_SSH_KEY=/Users/you/.ssh/VaisenKey.pem
# MOSHAVI_SSH_USER=ubuntu
# MOSHAVI_REMOTE_APP=/var/www/moshavi

# =============================================================================
# Local machine — optional Cloudflare cache purge when running ./scripts/deploy.sh
# =============================================================================
# Get Zone ID from Cloudflare dashboard → moshavi.com → Overview. Create API token with Zone → Cache Purge → Purge.
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=
